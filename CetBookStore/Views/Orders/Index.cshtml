@model List<CetBookStore.Models.Order>

@{
    ViewData["Title"] = "My Orders";
}

<h2>My Orders</h2>

@if (!Model.Any())
{
    <div class="alert alert-info">You have no orders yet.</div>
}
else
{
    @foreach (var order in Model)
    {
        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between">
                <span><strong>Order #@order.Id</strong> — @order.OrderDate.ToString("dd MMM yyyy HH:mm")</span>
                <span class="badge bg-success fs-6">@order.TotalPrice.ToString("C")</span>
            </div>
            <div class="card-body">
                <table class="table table-sm mb-0">
                    <thead>
                        <tr>
                            <th>Product Name</th>
                            <th>Quantity</th>
                            <th>Unit Price</th>
                            <th>Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in order.OrderItems)
                        {
                            <tr>
                                <td>@item.ProductName</td>
                                <td>@item.Quantity</td>
                                <td>@item.UnitPrice.ToString("C")</td>
                                <td>@((item.UnitPrice * item.Quantity).ToString("C"))</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
}
